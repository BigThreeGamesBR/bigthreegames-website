---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getSiteContent } from '../lib/content';

const { contact, global } = getSiteContent();
---

<BaseLayout
  title={contact.seo.title}
  description={contact.seo.description}
  pageClass="page-contact"
  activePage="contact"
>
  <section class="hero" aria-labelledby="contact-hero-title">
    <div class="hero__media">
      <img src={contact.hero.image} alt={contact.hero.imageAlt} loading="eager" />
    </div>
    <div class="hero__veil"></div>

    <div class="container hero__inner">
      <div class="hero__content reveal">
        <p class="hero__eyebrow">{contact.hero.eyebrow}</p>
        <h1 class="hero__title" id="contact-hero-title">{contact.hero.title}</h1>
        <p class="hero__summary">{contact.hero.summary}</p>
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="contact-direct-title">
    <div class="container contact-layout contact-layout--single">
      <article class="contact-card surface reveal stack" aria-labelledby="contact-direct-title">
        <p class="section__kicker">{contact.aside.kicker}</p>
        <h2 class="section__title" id="contact-direct-title">{contact.aside.heading}</h2>
        <p>{contact.aside.body}</p>
        <p>
          {contact.aside.emailLabel}
          <a href={`mailto:${global.contactEmail}`}> {global.contactEmail}</a>
        </p>
        <p>{contact.aside.servicesNote}</p>
      </article>
    </div>
  </section>

  <section class="cta-band" aria-labelledby="contact-social-title">
    <div class="container">
      <div class="cta-band__inner reveal split split--equal">
        <div class="stack">
          <p class="section__kicker">{contact.socialCta.kicker}</p>
          <h2 class="cta-band__title" id="contact-social-title">{contact.socialCta.title}</h2>
          <p>{contact.socialCta.body}</p>
        </div>

        <div class="cluster">
          {
            contact.socialCta.actions.map((action) => (
              <a
                class={`button button--${action.variant}`}
                href={action.href}
                target={action.external ? '_blank' : undefined}
                rel={action.external ? 'noopener noreferrer' : undefined}
              >
                {action.label}
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
