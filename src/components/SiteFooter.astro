---
import { getSiteContent } from '../lib/content';

const { global } = getSiteContent();
const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="stack">
      <a class="brand" href="/" aria-label={global.ui.brandHomeAriaLabel}>
        <img
          class="brand__mark brand__official-mark"
          src="/assets/studio/logo/b3g_official_logo.png"
          alt=""
          width="1024"
          height="1024"
          aria-hidden="true"
        />
        <span class="brand__type">
          <span class="brand__title">{global.siteName}</span>
        </span>
      </a>
      <p class="copyright">{global.ui.footerCopyrightPrefix} {currentYear} {global.siteName}. {global.tagline}</p>
    </div>

    <ul class="footer-links" aria-label={global.ui.footerLinksAriaLabel}>
      {
        global.footerLinks.map((link) => (
          <li>
            <a
              href={link.href}
              target={link.external ? '_blank' : undefined}
              rel={link.external ? 'noopener noreferrer' : undefined}
              aria-label={link.external ? `${link.label} (opens in new tab)` : undefined}
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</footer>
